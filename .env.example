# Database — local PostgreSQL (recommended for development)
# When you go live (~70–80% done), restore a backup to your cloud/VPS database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ws_computer_city?schema=public"

# NextAuth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="WS Computer City"

# File Upload (Choose one)
# Option 1: AWS S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME=""
AWS_REGION="ap-south-1"
AWS_CDN_DOMAIN=""

# Option 2: UploadThing (Recommended for easy start)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Redis (Optional - for caching)
REDIS_URL="redis://localhost:6379"

# Search (Optional)
# Typesense
TYPESENSE_HOST=""
TYPESENSE_PORT="443"
TYPESENSE_PROTOCOL="https"
TYPESENSE_API_KEY=""

# Monitoring (Optional)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Email (Optional - for order notifications)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@wscomputercity.com"

# Payment Gateway (For future implementation)
# SSL Commerz (Bangladesh)
SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWORD=""
SSLCOMMERZ_IS_LIVE="false"

# bKash
BKASH_APP_KEY=""
BKASH_APP_SECRET=""
BKASH_USERNAME=""
BKASH_PASSWORD=""
BKASH_IS_LIVE="false"

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=""
